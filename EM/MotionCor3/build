#!/usr/bin/env modbuild

pbuild::prep() {
    # Clone the repository with shallow depth
    git clone --depth=1 -b "main" "https://github.com/czimaginginstitute/${P}.git" "$SRC_DIR"

    # Ensure the bin directory exists in the installation path
    mkdir -p "$PREFIX/bin"
}

pbuild::configure() {
    :
}

pbuild::compile() {
    cd "$SRC_DIR"

    if [[ $(uname -m) == "aarch64" ]]; then
        # Remove x86-only flags
        find . -type f \( -iname 'makefile*' -o -iname '*.mk' \) \
            -exec sed -i 's/-m64//g' {} +

        # Optional: remove SSE/AVX flags too
        find . -type f \( -iname 'makefile*' -o -iname '*.mk' \) \
            -exec sed -i 's/-msse[^ ]*//g; s/-mavx[^ ]*//g' {} +
    fi

    # Clean old objects/libraries
    find . -name '*.o' -delete
    rm -f LibSrc/Lib/*.a

    # Build dependent libraries
    make -C TiffUtil
    make -C LibSrc/Util
    make -C LibSrc/Mrcfile

    # Build MotionCor3
    make -f makefile11 exe CUDAHOME="$CUDA_HOME"
}

pbuild::install() {
    # Copy the compiled binary to the installation directory
    install "$SRC_DIR/${P}" "$PREFIX/bin/"
}
